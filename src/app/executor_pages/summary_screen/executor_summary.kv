#:kivy 2.0

<ExecutorSummaryScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10

        # Header
        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 10

            Button:
                text: "< Back"
                size_hint_x: 0.15
                on_press: root.go_back()
                background_color: 0.2, 0.2, 0.35, 1

            Label:
                text: root.title
                size_hint_x: 0.6
                font_size: '18sp'
                bold: True

            Label:
                text: root.session_status
                size_hint_x: 0.25
                color: root.status_color
                font_size: '16sp'
                bold: True

        # Main content: two columns
        BoxLayout:
            spacing: 15

            # Left panel: Steps list (40%)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4

                Label:
                    text: "Steps"
                    size_hint_y: None
                    height: 30
                    font_size: '14sp'
                    bold: True

                ScrollView:
                    GridLayout:
                        id: steps_container
                        cols: 1
                        spacing: 5
                        size_hint_y: None
                        height: self.minimum_height

            # Right panel: Video and info (60%)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.6
                spacing: 10

                # Video player
                BoxLayout:
                    size_hint_y: 0.7

                    Video:
                        id: video_player
                        source: ''
                        state: 'play'
                        options: {'eos': 'loop'}
                        allow_stretch: True

                # Step info panel
                BoxLayout:
                    size_hint_y: 0.3
                    orientation: 'vertical'
                    padding: 10
                    spacing: 5
                    canvas.before:
                        Color:
                            rgba: 0.15, 0.15, 0.25, 1
                        Rectangle:
                            size: self.size
                            pos: self.pos

                    Label:
                        text: "Step Information"
                        size_hint_y: None
                        height: 25
                        font_size: '12sp'
                        bold: True

                    ScrollView:
                        Label:
                            id: step_info
                            text: "Select a step to view details"
                            size_hint_y: None
                            height: self.texture_size[1]
                            markup: True
                            font_size: '11sp'
