#:import dp kivy.metrics.dp

<DesignerCreateScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.10, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        spacing: 0

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), 0, dp(24), 0]
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.16, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "< Back"
                font_size: "13sp"
                size_hint: None, None
                size: dp(80), dp(40)
                pos_hint: {"center_y": 0.5}
                background_color: 0, 0, 0, 0
                color: 0.80, 0.90, 1.0, 1
                on_release: root.go_back()
                canvas.before:
                    Color:
                        rgba: 0.12, 0.12, 0.22, 0.7
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

            Label:
                text: "[b]Designer[/b]  —  Nuova Registrazione"
                markup: True
                font_size: "16sp"
                color: 0.85, 0.85, 1.0, 1
                halign: "left"
                valign: "center"
                text_size: self.size

        FloatLayout:
            BoxLayout:
                orientation: "vertical"
                padding: dp(32)
                spacing: dp(18)
                size_hint: None, None
                width: min(dp(480), root.width - dp(64))
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                canvas.before:
                    Color:
                        rgba: 0.09, 0.09, 0.18, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                height: self.minimum_height

                Label:
                    text: "Nome sessione"
                    font_size: "12sp"
                    color: 0.50, 0.50, 0.75, 1
                    size_hint_y: None
                    height: dp(18)
                    halign: "left"
                    text_size: self.size

                TextInput:
                    id: name_input
                    hint_text: "es. login_flow_v1"
                    multiline: False
                    font_size: "14sp"
                    background_color: 0.12, 0.12, 0.22, 1
                    foreground_color: 0.9, 0.9, 1, 1
                    cursor_color: 0.16, 0.75, 0.47, 1
                    hint_text_color: 0.30, 0.30, 0.50, 1
                    padding: [dp(12), dp(10)]
                    size_hint_y: None
                    height: dp(42)

                Label:
                    text: "Schermo da registrare"
                    font_size: "12sp"
                    color: 0.50, 0.50, 0.75, 1
                    size_hint_y: None
                    height: dp(18)
                    halign: "left"
                    text_size: self.size

                Spinner:
                    id: monitor_spinner
                    text: "Seleziona monitor"
                    font_size: "13sp"
                    background_color: 0, 0, 0, 0
                    color: 0.9, 0.9, 1, 1
                    values: ["Monitor 1  (1920×1080)"]
                    option_cls: 'StyledSpinnerOption'
                    size_hint_y: None
                    height: dp(42)
                    padding: [dp(12), dp(10)]
                    canvas.before:
                        Color:
                            rgba: 0.12, 0.12, 0.22, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
                        Color:
                            rgba: 0.25, 0.55, 0.95, 0.3
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(6))
                            width: 1

                Label:
                    text: "Cartella salvataggio"
                    font_size: "12sp"
                    color: 0.50, 0.50, 0.75, 1
                    size_hint_y: None
                    height: dp(18)
                    halign: "left"
                    text_size: self.size

                BoxLayout:
                    size_hint_y: None
                    height: dp(42)
                    spacing: dp(8)

                    TextInput:
                        id: output_folder_input
                        hint_text: "Scegli una cartella…"
                        multiline: False
                        font_size: "13sp"
                        background_color: 0.12, 0.12, 0.22, 1
                        foreground_color: 0.9, 0.9, 1, 1
                        cursor_color: 0.16, 0.75, 0.47, 1
                        hint_text_color: 0.30, 0.30, 0.50, 1
                        padding: [dp(12), dp(10)]

                    Button:
                        text: "Sfoglia"
                        size_hint_x: None
                        width: dp(80)
                        font_size: "13sp"
                        background_color: 0.18, 0.18, 0.32, 1
                        color: 0.80, 0.80, 1, 1
                        on_release: root.browse_output_folder()

                Label:
                    text: root._error_msg
                    font_size: "12sp"
                    color: 0.91, 0.30, 0.24, 1
                    size_hint_y: None
                    height: dp(18) if root._error_msg else 0
                    opacity: 1 if root._error_msg else 0
                    halign: "left"
                    text_size: self.size

                Button:
                    text: "Avvia Registrazione"
                    bold: True
                    font_size: "16sp"
                    size_hint_y: None
                    height: dp(56)
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    on_release: root.start()
                    canvas.before:
                        Color:
                            rgba: 0.25, 0.55, 0.95, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]
